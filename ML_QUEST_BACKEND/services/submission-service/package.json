{
  "name": "@ml-quest/submission-service",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "start": "node dist/index.js",
    "dev": "DOTENV_CONFIG_PATH=../../.env ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/judge.worker.ts",
    "ml-worker": "ts-node-dev --respawn --transpile-only src/ml/ml.worker.ts"
  },
  "dependencies": {
    "@ml-quest/shared": "*",
    "fastify": "latest",
    "@fastify/cors": "latest",
    "@fastify/helmet": "latest",
    "@fastify/rate-limit": "latest",
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/s3-request-presigner": "^3.400.0",
    "bullmq": "^5.7.0",
    "ioredis": "^5.4.1",
    "pg": "^8.11.5",
    "pino": "^9.5.0",
    "dotenv": "^16.4.1",
    "zod": "^3.22.4",
    "fastify-plugin": "^4.5.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.11.0"
  }
}